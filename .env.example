# ==============================================================================
# 🏦 BANKPILOT LOCAL DEVELOPMENT CONFIGURATION TEMPLATE
# ==============================================================================
# Rename this file to '.env' and fill in your secure credentials before starting.
# Under no circumstances should secrets or key files be committed to Git.
# ==============================================================================

# 🌐 GOOGLE CLOUD PLATFORM CONFIGURATION
# ------------------------------------------------------------------------------
# Your Google Cloud Project ID and regional resources location
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Google Storage bucket used for staging transaction and profile bulk CSV loads
GOOGLE_CLOUD_STAGING_BUCKET=gs://your-staging-bucket-name

# 🗝️ SECURE ACCESS & CREDENTIALS
# ------------------------------------------------------------------------------
# Relative or absolute file path to your service account key file (JSON format)
# Ensure this file is ignored under your .gitignore rules!
GOOGLE_APPLICATION_CREDENTIALS=./keys/service-account.json

# 📊 BIGQUERY DATASTORE CONFIGURATIONS
# ------------------------------------------------------------------------------
# The project and dataset names where your tables, views, and schemas are built
BQ_PROJECT_ID=your-gcp-project-id
BQ_DATASET_ID=banking_data

# Relative path to your dataset config mapping
DATASET_CONFIG_FILE=./app/banking_dataset_config.json

# 🤖 MULTI-AGENT MODELS CONFIGURATION (VERTEX AI / GEMINI)
# ------------------------------------------------------------------------------
# Gemini models used by each agent. 'gemini-2.5-pro' is recommended for complex
# reasoning (such as NL2SQL), while 'gemini-2.5-flash' offers rapid intent routing.
ROOT_AGENT_MODEL=gemini-2.5-pro
BIGQUERY_AGENT_MODEL=gemini-2.5-pro
TRANSACTION_AGENT_MODEL=gemini-2.5-flash

# 🔌 MICROSERVICES NETWORK ENDPOINTS
# ------------------------------------------------------------------------------
# Port and path routing configurations for your local development servers
MCP_SERVER_URL=http://localhost:8080/mcp
IDENTITY_SERVICE_URL=http://localhost:8080
FRONTEND_PORT=3000
AGENT_PORT=8501
