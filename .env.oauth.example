# OAuth 2.0 Configuration for MCP Server
# Uncomment and fill in these values if your MCP server uses OAuth 2.0

# OAuth 2.0 Client Credentials
# MCP_OAUTH_CLIENT_ID=your_client_id_here
# MCP_OAUTH_CLIENT_SECRET=your_client_secret_here

# OAuth 2.0 Token Endpoint
# MCP_OAUTH_TOKEN_URL=https://your-auth-server.com/oauth/token

# OAuth 2.0 Scope (optional)
# MCP_OAUTH_SCOPE=read:mcp write:mcp

# MCP Server URL (existing setting)
MCP_SERVER_URL=http://localhost:8080/mcp

# Transaction Agent Model
TRANSACTION_AGENT_MODEL=gemini-2.5-flash
